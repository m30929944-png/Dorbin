# این فایل رو کپی کن به .env و مقادیر واقعی رو بذار — .env هرگز نباید commit بشه

PORT=4000

# آدرس دیتابیس واقعی MongoDB (مثلاً از MongoDB Atlas - رایگان)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.mongodb.net/bamgram?retryWrites=true&w=majority

# رشته‌های تصادفی و طولانی برای امضای JWT (با هر ابزار تولید رمز عبور بسازشون)
JWT_ACCESS_SECRET=change-this-to-a-long-random-string
JWT_REFRESH_SECRET=change-this-to-a-different-long-random-string

# آدرس فرانت‌اند برای تنظیم CORS (آدرس واقعی سایتت وقتی دیپلوی شد)
CLIENT_ORIGIN=http://localhost:5500
